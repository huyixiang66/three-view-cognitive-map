# API Keys for Three-View Cognitive Map
# Copy this file to .env and fill in your keys

# WellAPI key (used by deepseek-v3, gemini-3.5-flash)
WELLAPI_API_KEY=sk-your-wellapi-key-here

# DashScope key (used by qwen-plus, qwen-turbo)
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# OpenAI key (used by gpt-4o)
OPENAI_API_KEY=sk-your-openai-key-here
